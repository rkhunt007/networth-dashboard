DATABASE_URL="file:./dev.db"
EXCHANGE_RATE_API_KEY="<get free key from https://exchangerate-api.com>"

# Auth (required) — session cookie encryption secret, must be 32+ chars
NUXT_SESSION_PASSWORD="<random 32+ character string>"
# Password users must enter to access the app
APP_PASSWORD="<choose a strong password>"

# Turso (production only) — leave UNSET locally to fall back to prisma/dev.db
# Get these from: turso db show <db> --url  and  turso db tokens create <db>
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""
